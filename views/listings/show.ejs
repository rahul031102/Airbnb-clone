<% layout("layouts/boilerplate", { bodyClass: "show-page" }) %>

<div
  class="show-bg"
  style="--bg-img: url('<%= listing.image %>')"
></div>

<div class="container show-content py-5">

  <h1 class="mb-3"><%= listing.title %></h1>

  <img
    src="<%= listing.image %>"
    class="img-fluid rounded mb-4"
    alt="listing image"
  >

  <p class="lead"><%= listing.description %></p>

  <h3>₹ <%= listing.price.toLocaleString("en-IN") %></h3>

  <p>
    <strong><%= listing.location.city %></strong>,
    <%= listing.location.country %>
  </p>

  <div class="d-flex gap-2 mt-4">
    <a
      href="/listings/<%= listing._id %>/edit"
      class="btn btn-warning"
    >
      Update
    </a>

    <form
      method="POST"
      action="/listings/<%= listing._id %>?_method=DELETE"
    >
      <button class="btn btn-danger" type="submit">
        Delete
      </button>
    </form>
  </div>

</div>
