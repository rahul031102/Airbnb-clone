<% layout("layouts/boilerplate", { bodyClass: "listings-page" }) %>
<br>

<h1 class="mb-4">All Listings</h1>
<!-- <% if (success.length > 0) { %>
  <div class="alert alert-success" role="alert">
    <%= success[0] %>
  </div>
<% } %> -->

<div class="row g-4">
  <% for (let listing of listings) { %>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card h-100">
        <a href="/listings/<%= listing._id %>/show"
	class="anchor">
	<img 
  src="<%= typeof listing.image === 'string' ? listing.image : listing.image.url %>" 
  class="card-img-top" 
  alt="listing image"
>
	</a>
        <div class="card-body d-flex flex-column">
               <a href="/listings/<%= listing._id %>/show">
		 <h5 class="card-title"><%= listing.title %></h5>
          </a>
	<a
            href="/listings/<%= listing._id %>/show"
            class="btn btn-primary mt-auto"
          >
            See details
          </a>
        </div>
      </div>
    </div>
  <% } %>
</div>
