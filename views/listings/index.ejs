<% layout("layouts/boilerplate", { bodyClass: "listings-page" }) %>
<br>
<div class="container">
<div class ="filters-wrapper">
<div class ="filters-container">

<div class="filters">

  <div class="filter">
    <i class="fa-solid fa-fire"></i>
    <p>Trending</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-bed"></i>
    <p>Rooms</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-city"></i>
    <p>Iconic Cities</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-mountain"></i>
    <p>Mountains</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-chess-rook"></i>
    <p>Castles</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-water"></i>
    <p>Amazing Pools</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-campground"></i>
    <p>Camping</p>
  </div>

  <div class="filter">
    <i class="fa-solid fa-tractor"></i>
    <p>Farms</p>
  </div>

  <div class="filter">
    <i class="fa-regular fa-snowflake"></i>
    <p>Arctic</p>
  </div>
  </div>
</div>

  <div class="tax-toggle">
  <span>Display total (incl. tax)</span>
  <label class="switch">
    <input type="checkbox" id="taxSwitch">
    <span class="slider"></span>
  </label>
</div>

</div>

</div>

<h1 class="mb-4">All Listings</h1>
<!-- <% if (success.length > 0) { %>
  <div class="alert alert-success" role="alert">
    <%= success[0] %>
  </div>
<% } %> -->

<div class="row g-4">
  <% for (let listing of listings) { %>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card h-100">
        <a href="/listings/<%= listing._id %>/show"
	class="anchor">
	<img 
  src="<%= typeof listing.image === 'string' ? listing.image : listing.image.url %>" 
  class="card-img-top" 
  alt="listing image"
>
	</a>
        <div class="card-body d-flex flex-column">
               <a href="/listings/<%= listing._id %>/show">
		 <h5 class="card-title"><%= listing.title %></h5>

<p class="price" data-price="<%= listing.price %>">
  ₹ <%= listing.price %> / night
</p>

          </a>
	<a
            href="/listings/<%= listing._id %>/show"
            class="btn btn-primary mt-auto"
          >
            See details
          </a>
        </div>
      </div>
    </div>
  <% } %>
</div>
