<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Wanderlust Listings</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css">
</head>
<body>

  <h1>All Listings</h1>

  <div class="listings">

    <% if (listings && listings.length) { %>

      <% for (let listing of listings) { %>

        <div class="card">
          <img
            src="<%= listing.image %>"
            alt="listing image"
            loading="lazy"
          >

          <h2><%= listing.title %></h2>
          <p>₹ <%= listing.price %></p>
        </div>

      <% } %>

    <% } else { %>
      <p>No listings found.</p>
    <% } %>

  </div>

</body>
</html>
